<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="600.0" style="-fx-background-color: #0b2b18; -fx-border-color: #d4af37; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ed.masanz.ut9.blackjackfx.HostConfigController">
    <center>
        <VBox alignment="CENTER" maxWidth="450.0" prefHeight="450.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: #104c26; -fx-border-color: #d4af37; -fx-border-radius: 15; -fx-background-radius: 15; -fx-border-width: 2;" BorderPane.alignment="CENTER">
