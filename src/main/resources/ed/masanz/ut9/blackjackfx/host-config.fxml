               <effect>
                  <DropShadow />
               </effect>
                </Label>
                <VBox spacing="5.0">
                    <children>
                        <Label text="NOMBRE DE LA SALA" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtnombresala" promptText="Inserta un nombre de sala..." style="-fx-background-radius: 10; -fx-padding: 8;" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="NÚMERO DE JUGADORES (2-6)" textFill="WHITE">
