                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtnumerojugadores" maxWidth="100.0" prefHeight="33.0" prefWidth="69.0" style="-fx-background-radius: 10; -fx-padding: 8;" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="TIPO DE SALA" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="20.0">
                            <children>
                                <RadioButton fx:id="rbtPublico" mnemonicParsing="false" selected="true" text="Pública" textFill="WHITE">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="tipoGrupo" />
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton fx:id="rbtPrivado" mnemonicParsing="false" text="Privada" textFill="WHITE" toggleGroup="$tipoGrupo" />
