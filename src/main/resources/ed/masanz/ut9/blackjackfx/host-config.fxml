                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button mnemonicParsing="false" onAction="#crearSala" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: linear-gradient(to bottom, #f4c453, #c58f22); -fx-text-fill: black; -fx-background-radius: 10;" text="CREAR SALA">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </bottom>
   <top>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
