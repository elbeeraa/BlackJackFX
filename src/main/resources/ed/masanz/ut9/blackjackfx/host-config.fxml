                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                        <ImageView fx:id="imagen" fitHeight="91.0" fitWidth="102.0" onMouseClicked="#cambiarImagen" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../../images/imagen_defecto.png" />
                           </image>
                        </ImageView>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
            <BorderPane.margin>
                <Insets top="20.0" />
            </BorderPane.margin>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="80.0" prefWidth="600.0" spacing="30.0" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #8b0000; -fx-text-fill: white; -fx-background-radius: 10;" text="CANCELAR">
